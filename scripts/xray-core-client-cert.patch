+// hasClientCert reports whether any configured certificate is marked for
+// client-side mutual-TLS presentation (usage "client-cert").
+func (c *Config) hasClientCert() bool {
+	for _, cert := range c.Certificate {
+		if cert.Usage == Certificate_MTLS_CLIENT_CERT {
+			return true
+		}
+	}
+	return false
+}
+
+// getClientCertificate is the tls.Config.GetClientCertificate callback for
+// outbound mutual TLS. It returns the first configured MTLS_CLIENT_CERT whose
+// key pair satisfies the server's CertificateRequest (acceptable CAs and
+// signature schemes), mirroring upstream's mtls-branch behaviour.
+func (c *Config) getClientCertificate(cri *tls.CertificateRequestInfo) (*tls.Certificate, error) {
+	for _, entry := range c.Certificate {
+		if entry.Usage != Certificate_MTLS_CLIENT_CERT {
+			continue
+		}
+		keyPair, err := tls.X509KeyPair(entry.Certificate, entry.Key)
+		if err != nil {
+			errors.LogWarningInner(context.Background(), err, "ignoring invalid client X509 key pair")
+			continue
+		}
+		if keyPair.Leaf, err = x509.ParseCertificate(keyPair.Certificate[0]); err != nil {
+			errors.LogWarningInner(context.Background(), err, "ignoring invalid client certificate")
+			continue
+		}
+		if err := cri.SupportsCertificate(&keyPair); err == nil {
+			return &keyPair, nil
+		}
+	}
+	return nil, errNoCertificates
+}
